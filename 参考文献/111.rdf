    <bib:Article rdf:about="https://kns.cnki.net/KCMS/detail/detail.aspx?dbcode=CJFQ&amp;dbname=CJFDLAST2018&amp;filename=DLXT201801007">
        <z:itemType>journalArticle</z:itemType>
        <dcterms:isPartOf>
            <bib:Journal>
                <prism:volume>42</prism:volume>
                <dc:title>电力系统自动化</dc:title>
                <prism:number>1</prism:number>
            </bib:Journal>
        </dcterms:isPartOf>
        <bib:authors>
            <rdf:Seq>
                <rdf:li>
                   <foaf:Person><foaf:surname>王林炎</foaf:surname></foaf:Person>
                </rdf:li>
