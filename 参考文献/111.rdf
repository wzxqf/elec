        <dc:subject>
           <z:AutomaticTag><rdf:value>电力市场</rdf:value></z:AutomaticTag>
        </dc:subject>
        <dc:subject>
           <z:AutomaticTag><rdf:value>交易机制</rdf:value></z:AutomaticTag>
        </dc:subject>
        <dc:subject>
           <z:AutomaticTag><rdf:value>可再生能源</rdf:value></z:AutomaticTag>
        </dc:subject>
