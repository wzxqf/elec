    <bib:Article rdf:about="https://kns.cnki.net/KCMS/detail/detail.aspx?dbcode=CJFQ&amp;dbname=CJFD2010&amp;filename=DLXT201003006">
        <z:itemType>journalArticle</z:itemType>
        <dcterms:isPartOf>
            <bib:Journal>
                <prism:volume>34</prism:volume>
                <dc:title>电力系统自动化</dc:title>
                <prism:number>3</prism:number>
            </bib:Journal>
        </dcterms:isPartOf>
        <bib:authors>
            <rdf:Seq>
                <rdf:li>
                   <foaf:Person><foaf:surname>张钦</foaf:surname></foaf:Person>
                </rdf:li>
