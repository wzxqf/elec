                <rdf:value>https://ieeexplore.ieee.org/stamp/stamp.jsp?tp=&amp;arnumber=9535386</rdf:value>
            </dcterms:URI>
        </dc:identifier>
        <dcterms:dateSubmitted>2026-03-31 09:28:12</dcterms:dateSubmitted>
    </bib:Article>
