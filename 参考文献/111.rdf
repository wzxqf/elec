    <bib:Article rdf:about="https://doi.org/10.13335/j.1000-3673.pst.2016.11.004">
        <z:itemType>journalArticle</z:itemType>
        <dcterms:isPartOf>
            <bib:Journal>
                <prism:volume>40</prism:volume>
                <dc:title>电网技术</dc:title>
                <dc:identifier>DOI 10.13335/j.1000-3673.pst.2016.11.004</dc:identifier>
                <prism:number>11</prism:number>
            </bib:Journal>
        </dcterms:isPartOf>
        <bib:authors>
            <rdf:Seq>
                <rdf:li>
                   <foaf:Person><foaf:surname>杨萌</foaf:surname></foaf:Person>
                </rdf:li>
